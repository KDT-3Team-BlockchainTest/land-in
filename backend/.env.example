# ──────────────────────────────────────────────
# .env.example — 이 파일을 .env로 복사 후 값 입력
# ──────────────────────────────────────────────

# 블록체인 (Hoodi testnet)
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_SKIP_METADATA_URL_CHECK=true
BLOCKCHAIN_MINTER_PRIVATE_KEY=여기에_MetaMask_개인키_입력

# NFC SUN/SDM (NTAG 424 DNA 태그 설정 시 입력)
# NFC_SDM_ENABLED=true
# NFC_SDM_ENC_KEY=태그_설정시_SDMMetaReadKey_hex
# NFC_SDM_MAC_KEY=태그_설정시_SDMFileReadKey_hex
